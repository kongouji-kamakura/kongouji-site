---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FadeIn from '@/components/FadeIn.astro';
import CallButton from '@/components/CallButton.astro';
import BackgroundDecor from '@/components/BackgroundDecor.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import houjiSogiHero from '@/assets/photos/houji-sogi-hero.jpg';
import { site } from '@/data/site';

// ご相談時に分かる範囲で伺う事項。各アイコンは控えめな線アイコンを統一トーンで使用。
const inquiryItems = [
  { icon: 'lucide:calendar', text: 'ご希望の日時' },
  { icon: 'lucide:hand-helping', text: 'ご法事またはご葬儀の内容' },
  { icon: 'lucide:user-round', text: '故人様のお名前' },
  { icon: 'lucide:calendar-heart', text: 'ご命日' },
  { icon: 'lucide:map-pin', text: 'ご希望のお勤め場所' },
  { icon: 'lucide:users', text: 'ご参列人数の目安' },
  { icon: 'lucide:building-2', text: 'ご葬儀の場合は、葬儀社様がお決まりかどうか' },
];
---
<BaseLayout
  title="ご法事・ご葬儀のご相談"
  description={`${site.fullName}では、金剛寺本堂でのお勤めをはじめ、ご自宅・霊園・墓地など、それぞれの場所や形に合わせてご相談を承っております。ご法事は関東圏を中心にお伺いすることもございます。まずはお電話にてお気軽にご相談ください。`}
>
  <!-- 大判ヒーロー：祭壇の写真を背景に -->
  <section class="relative overflow-hidden bg-ink/5">
    <div class="relative h-[62vh] min-h-[440px] sm:h-[72vh] sm:min-h-[560px] w-full overflow-hidden">
      <Image
        src={houjiSogiHero}
        alt="金剛寺 ご法事のお勤めの場"
        loading="eager"
        decoding="async"
        class="hero-image absolute inset-0 w-full h-full object-cover"
      />
      <!-- 上下に自然なグラデーション（読みやすさのため） -->
      <div class="absolute inset-x-0 top-0 h-1/3 bg-gradient-to-b from-paper/35 to-transparent pointer-events-none" aria-hidden="true"></div>
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-paper via-paper/40 to-transparent pointer-events-none" aria-hidden="true"></div>
    </div>

    <!-- 写真の下に重なるタイトル -->
    <div class="section relative">
      <div class="-mt-40 sm:-mt-52 max-w-3xl mx-auto text-center fade-in relative z-10">
        <p class="text-xs sm:text-sm tracking-wider2 uppercase text-gold mb-5">
          Memorial Service
        </p>
        <h1 class="font-serif text-3xl sm:text-5xl md:text-6xl text-ink leading-snug">
          ご法事・ご葬儀のご相談
        </h1>
      </div>
    </div>
  </section>

  <!-- 本文 -->
  <section class="relative section section-padding">
    <BackgroundDecor variant="houji-sogi" />

    <div class="max-w-2xl mx-auto">
      <FadeIn>
        <div class="space-y-6 text-inkSoft leading-loose text-sm sm:text-base">
          <p>ご法事・ご葬儀は、ご家庭ごとにご事情やご希望が異なります。</p>
          <p>
            金剛寺では、金剛寺本堂でのお勤めをはじめ、ご自宅、霊園、墓地など、それぞれの場所や形に合わせてご相談を承っております。
          </p>
          <p>
            ご法事につきましては、関東圏を中心にお伺いすることもございます。遠方の場合は、日程や場所によりご相談となりますので、まずはお電話にてお問い合わせください。
          </p>
          <p>
            Web上での自動予約は行っておりません。日時や場所、お勤めの内容などを丁寧に伺いながら、一つひとつご相談を承っております。
          </p>
          <p>
            はじめてご相談される方も、分かる範囲で構いません。どうぞお気軽にご連絡ください。
          </p>
        </div>
      </FadeIn>

      <!-- ご相談の際の案内カード -->
      <FadeIn delay={120}>
        <aside class="mt-10 sm:mt-12 rounded-2xl border border-line bg-paperWarm/40 p-6 sm:p-10">
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-fujiSoft text-inkSoft">
              <Icon name="lucide:scroll-text" class="w-5 h-5" aria-hidden="true" />
            </span>
            <p class="text-xs tracking-wider2 uppercase text-gold">For Inquiry</p>
          </div>
          <h2 class="font-serif text-lg sm:text-xl text-ink mb-6">
            ご相談の際、分かる範囲でお知らせください
          </h2>
          <ul class="space-y-3 sm:space-y-4 text-inkSoft text-sm sm:text-base leading-relaxed">
            {inquiryItems.map((item) => (
              <li class="flex items-start gap-3">
                <span class="inline-flex items-center justify-center w-5 h-5 text-gold shrink-0 mt-0.5">
                  <Icon name={item.icon} class="w-4 h-4" aria-hidden="true" />
                </span>
                <span>{item.text}</span>
              </li>
            ))}
          </ul>
          <p class="text-xs text-inkMuted leading-relaxed mt-6">
            ※ ご相談の段階で分からない事項がありましても、構いません。お電話で一緒に整理させていただきます。
          </p>
        </aside>
      </FadeIn>

      <!-- 電話CTAカード -->
      <FadeIn delay={240}>
        <div class="mt-10 sm:mt-12 rounded-2xl border border-line bg-paper p-6 sm:p-10">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-fujiSoft text-inkSoft">
              <Icon name="lucide:phone" class="w-5 h-5" aria-hidden="true" />
            </span>
            <p class="text-xs tracking-wider2 uppercase text-gold">Contact</p>
          </div>
          <h3 class="font-serif text-xl sm:text-2xl text-ink mb-3">
            お電話で相談する
          </h3>
          <p class="text-inkSoft text-sm leading-relaxed mb-6">
            ご事情を丁寧にお伺いしながら、ご相談を承ります。
          </p>
          <p class="font-serif text-3xl sm:text-4xl text-ink mb-6">
            <a href={`tel:${site.phoneTel}`} class="hover:text-gold transition-colors">
              {site.phone}
            </a>
          </p>
          <CallButton />
        </div>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
