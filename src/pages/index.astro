---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import GuideCard from '@/components/GuideCard.astro';
import FadeIn from '@/components/FadeIn.astro';
import CallButton from '@/components/CallButton.astro';
import MapButton from '@/components/MapButton.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import historyKongoujiCurrent from '@/assets/photos/history-kongouji-current.jpg';
import { site } from '@/data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const cards = [
  {
    href: `${base}/houwakai/`,
    title: '法話会のご案内',
    description: '毎月第二土曜日 13時半より、法話会を行っております。はじめての方もどうぞお参りください。',
    icon: 'lucide:book-open',
  },
  {
    href: `${base}/events/`,
    title: '年間行事',
    description: '元旦会・春秋のお彼岸・永代経・お盆・報恩講など、季節ごとのご縁を大切にお勤めしております。',
    icon: 'lucide:calendar-days',
  },
  {
    href: `${base}/houji-sogi/`,
    title: 'ご法事・ご葬儀のご相談',
    description: 'ご法事・ご葬儀につきましては、まずはお電話にてお気軽にご相談ください。',
    icon: 'lucide:hand-helping',
  },
  {
    href: `${base}/gassobo/`,
    title: '金剛寺 合葬墓のご案内',
    description: '合葬墓のご案内と、一時お骨預かりについてもこちらでご紹介しております。',
    icon: 'lucide:square-stack',
  },
  {
    href: `${base}/access/`,
    title: 'アクセス・駐車場',
    description: '大船駅より徒歩約16分。駐車場は3台ほどございます（台数に限りがあります）。',
    icon: 'lucide:map-pin',
  },
];
---
<BaseLayout description={site.description}>
  <Hero />

  <section class="section section-padding">
    <FadeIn>
      <SectionHeading eyebrow="Guide" title="金剛寺のご案内" align="center" />
    </FadeIn>
    <FadeIn>
      <div class="grid gap-5 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {cards.map((c) => (
          <GuideCard href={c.href} title={c.title} description={c.description} icon={c.icon} />
        ))}
      </div>
    </FadeIn>
  </section>

  <!-- 金剛寺の歩みフィーチャーバナー -->
  <section class="section section-padding">
    <FadeIn>
      <a
        href={`${base}/history/`}
        class="group block relative overflow-hidden rounded-3xl border border-line card-hover"
      >
        <div class="grid lg:grid-cols-12 lg:min-h-[420px]">
          <!-- 写真側 -->
          <div class="relative lg:col-span-7 aspect-[16/10] lg:aspect-auto overflow-hidden bg-paperWarm">
            <Image
              src={historyKongoujiCurrent}
              alt="現在の金剛寺"
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              loading="lazy"
            />
            <!-- モバイルでは下にグラデーション、デスクトップでは右にグラデーション -->
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-paper via-paper/30 to-transparent lg:hidden pointer-events-none" aria-hidden="true"></div>
            <div class="hidden lg:block absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-paper via-paper/40 to-transparent pointer-events-none" aria-hidden="true"></div>
          </div>
          <!-- 文字側 -->
          <div class="lg:col-span-5 px-6 py-10 sm:px-10 sm:py-14 lg:py-14 flex flex-col justify-center bg-paper">
            <p class="text-xs tracking-wider2 uppercase text-gold mb-3">History · Showa 42 — Today</p>
            <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl text-ink mb-5 leading-snug">
              金剛寺の歩み
            </h2>
            <p class="text-inkSoft leading-relaxed text-sm sm:text-base mb-7">
              昭和42年の築地本願寺での集いから、現在の大船山 金剛寺に至るまで。
              ご門信徒の方々の聞法の願いとともに重ねられてきた歩みをご紹介します。
            </p>
            <span class="inline-flex items-center gap-2 text-sm text-gold opacity-90 group-hover:opacity-100 transition-opacity">
              <span>歩みを見る</span>
              <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true" />
            </span>
          </div>
        </div>
      </a>
    </FadeIn>
  </section>

  <section class="section section-padding">
    <FadeIn>
      <div class="rounded-3xl border border-line bg-paperWarm/40 px-6 py-12 sm:px-12 sm:py-16 text-center">
        <p class="text-xs tracking-wider2 uppercase text-gold mb-3">Contact</p>
        <h2 class="text-2xl sm:text-3xl font-serif text-ink mb-4">
          ご相談は、まずお電話にて
        </h2>
        <p class="text-inkSoft leading-relaxed mb-8 max-w-xl mx-auto">
          ご法事・ご葬儀、合葬墓、お骨預かりなどのご相談は、Web上での予約は承っておりません。<br />
          お電話にて直接お問い合わせいただけますと幸いです。
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <CallButton />
          <MapButton />
        </div>
      </div>
    </FadeIn>
  </section>
</BaseLayout>
