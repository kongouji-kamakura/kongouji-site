---
import '@/assets/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { site } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = site.description,
  // TODO[image]: 公開前に og-image.svg を 1200x630 の og-image.png に差し替え（SNS互換性のため）
  ogImage = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/og-image.svg`,
} = Astro.props;

const pageTitle = title ? `${title} | ${site.fullName}` : site.fullName;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.siteUrl).toString();

const ld = {
  '@context': 'https://schema.org',
  '@type': 'BuddhistTemple',
  name: site.fullName,
  url: site.siteUrl,
  telephone: site.phone,
  address: {
    '@type': 'PostalAddress',
    postalCode: site.postal,
    streetAddress: site.address,
    addressCountry: 'JP',
  },
};
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FAF7F2" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content={site.fullName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@400;500;600;700&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-paper focus:px-4 focus:py-2 focus:rounded-full focus:border focus:border-line"
    >
      本文へスキップ
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
