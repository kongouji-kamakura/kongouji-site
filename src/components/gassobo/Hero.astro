---
import { Image } from 'astro:assets';
import zenkeiImg from '@/assets/photos/gassobo-zenkei.jpg';
---
<section class="relative overflow-hidden">
  <!-- 全景写真をフルブリードで -->
  <div class="relative h-[68vh] min-h-[480px] sm:h-[80vh] sm:min-h-[600px] w-full overflow-hidden">
    <Image
      src={zenkeiImg}
      alt="金剛寺 合葬墓と富士山"
      loading="eager"
      decoding="async"
      class="hero-image absolute inset-0 w-full h-full object-cover"
    />

    <!-- 上下に控えめなグラデーション。
         上：タイトル可読性のため、ごくうっすら paper を被せる
         下：本文へ自然につなぐため paper まで滑らかにフェード -->
    <div class="absolute inset-x-0 top-0 h-1/3 bg-gradient-to-b from-paper/25 to-transparent pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-paper via-paper/45 to-transparent pointer-events-none" aria-hidden="true"></div>

    <!-- タイトル：写真上に静かに配置 -->
    <div class="absolute inset-x-0 top-[36%] sm:top-[40%] flex items-center justify-center px-6 pointer-events-none">
      <div class="text-center max-w-2xl fade-in">
        <p class="text-xs sm:text-sm tracking-wider2 uppercase text-gold mb-4 drop-shadow-[0_1px_2px_rgba(250,247,242,0.6)]">
          Gasso-bo
        </p>
        <h1 class="font-serif text-3xl sm:text-5xl md:text-6xl text-ink leading-snug drop-shadow-[0_1px_3px_rgba(250,247,242,0.6)]">
          金剛寺 合葬墓のご案内
        </h1>
      </div>
    </div>
  </div>
</section>
