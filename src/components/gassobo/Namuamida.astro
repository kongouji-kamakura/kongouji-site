---
import { Image } from 'astro:assets';
import kinkeiImg from '@/assets/photos/gassobo-kinkei.jpg';
import FadeIn from '@/components/FadeIn.astro';
import Parallax from '@/components/Parallax.astro';
import { site } from '@/data/site';
---
<section class="section section-padding">
  <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
    <!-- 近景写真：縦長を活かして大胆に -->
    <FadeIn class="lg:col-span-5 lg:order-2">
      <Parallax speed={0.06}>
        <figure class="relative">
          <div class="rounded-2xl overflow-hidden border border-line bg-paperWarm shadow-lg shadow-ink/5 aspect-[3/4]">
            <Image
              src={kinkeiImg}
              alt="墓碑正面に刻まれた南無阿弥陀仏 ― 金剛寺 合葬墓"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <!-- 控えめな金色の細い装飾線 -->
          <div class="absolute -top-3 -right-3 w-16 h-16 border-t border-r border-gold/40 hidden sm:block" aria-hidden="true"></div>
          <div class="absolute -bottom-3 -left-3 w-16 h-16 border-b border-l border-gold/40 hidden sm:block" aria-hidden="true"></div>
        </figure>
      </Parallax>
    </FadeIn>

    <!-- テキスト：余白を活かした静かな見せ方 -->
    <FadeIn delay={120} class="lg:col-span-7 lg:order-1">
      <div class="max-w-prose">
        <p class="text-xs tracking-wider2 uppercase text-gold mb-6">Namu Amida Butsu</p>
        <p class="font-serif text-2xl sm:text-3xl md:text-4xl text-ink leading-relaxed mb-10">
          {site.gassobo.shinpitsu}
        </p>
        <div class="divider-soft mb-10" />
        <p class="text-inkSoft leading-loose text-sm sm:text-base">
          墓碑正面に刻まれた「南無阿弥陀仏」の六字は、浄土真宗の宗祖 親鸞聖人の自筆文字をもとに刻まれています。
          手を合わせる方々の心に、静かに寄り添うお名号です。
        </p>
      </div>
    </FadeIn>
  </div>
</section>
