---
import FadeIn from '@/components/FadeIn.astro';
---
<section class="section pt-16 sm:pt-24 pb-8 sm:pb-12 text-center">
  <FadeIn>
    <p class="text-xs sm:text-sm tracking-wider2 uppercase text-gold mb-5">
      History · Showa 42 — Today
    </p>
  </FadeIn>
  <FadeIn delay={120}>
    <h1 class="font-serif text-3xl sm:text-5xl md:text-6xl text-ink leading-snug">
      金剛寺の歩み
    </h1>
  </FadeIn>
  <FadeIn delay={220}>
    <div class="mt-10 sm:mt-14 max-w-xs mx-auto">
      <div class="divider-soft" />
    </div>
  </FadeIn>
</section>
