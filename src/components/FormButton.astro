---
import { Icon } from 'astro-icon/components';
import { site } from '@/data/site';

interface Props {
  variant?: 'primary' | 'secondary';
  label?: string;
  class?: string;
}
const { variant = 'primary', label = '法要受付フォームを開く', class: className = '' } = Astro.props;
const cls = variant === 'primary' ? 'btn-primary' : 'btn-secondary';
---
<a
  href={site.formUrl}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[cls, className]}
  aria-label="法要受付フォームを開く（新しいタブで開きます）"
>
  <Icon name="lucide:clipboard-list" class="w-4 h-4" aria-hidden="true" />
  <span>{label}</span>
</a>
